meta {
  name: OdsInstances by ID Education Organizations
  type: http
  seq: 27
}

get {
  url: {{API_URL}}/v2/odsInstances/{{ODSInstanceId}}/edOrgs
  body: none
  auth: inherit
}

script:pre-request {
  console.log("🔧 Setting pre environment to ignore SSL certificates...");

  // Safely set Node.js environment variable if available (CLI only)
  try {
    if (typeof process !== 'undefined' && process.env) {
      process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
    }
  } catch (e) {
    // Ignore in UI environment
  }

  const axios = require('axios');
  const API_URL = bru.getEnvVar("API_URL");
  const TOKEN = bru.getEnvVar("TOKEN");

  // Configure axios to handle SSL and network issues
  const axiosConfig = {
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${TOKEN}`
    },
    validateStatus: function (status) {
      return status < 500;
    },
    timeout: 30000
  };

  // Add tenant header if multitenant mode is enabled
  if (bru.getEnvVar("isMultitenant") == "true") {
    axiosConfig.headers['Tenant'] = `${bru.getEnvVar("tenant1")}`;
  }

  try {
    let offsetVar = bru.getEnvVar("offset");
    let limitVar = bru.getEnvVar("limit");
    const odsResponse = await axios.get(`${API_URL}/v2/odsInstances?offset=${offsetVar}&limit=${limitVar}`, axiosConfig);

    if (odsResponse.status === 200) {
      console.log("✅ OdsInstance List loaded");
      bru.setVar("ODSInstanceId", odsResponse.data[0].id);
    } else {
      console.log("❌ Failed to get odsInstances");
      console.log("Status:", odsResponse.status);
      console.log("Response data:", JSON.stringify(odsResponse.data, null, 2));
      throw new Error(`Failed to get odsInstances - Status: ${odsResponse.status}, Data: ${JSON.stringify(odsResponse.data)}`);
    }
  } catch (error) {
    console.log("Error in pre-request setup:", error.message);
    throw error;
  }
}

script:post-response {
  const response = res.getBody();
  const Ajv = require('ajv');
  const ajv = new Ajv();

  test("GET OdsInstances by ID EdOrgs: Status code is OK", function () {
      expect(res.getStatus()).to.equal(200);
  });

  const OdsInstancesEdOrgsByIdSchema = {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "dbInstanceId": { "type": ["integer", "null"] },
        "name": { "type": "string" },
        "instanceType": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] },
        "databaseTemplate": { "type": ["string", "null"] },
        "databaseName": { "type": ["string", "null"] },
        "educationOrganizations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "educationOrganizationId": { "type": "integer" },
              "nameOfInstitution": { "type": "string" },
              "shortNameOfInstitution": { "type": ["string", "null"] },
              "discriminator": { "type": "string" },
              "parentId": { "type": ["integer", "null"] }
            },
            "required": ["educationOrganizationId", "nameOfInstitution", "discriminator"]
          }
        }
      },
      "required": ["id", "name", "educationOrganizations"]
    }
  };

  test("GET OdsInstances by ID EdOrgs: Response matches schema", function () {
      expect(ajv.validate(OdsInstancesEdOrgsByIdSchema, response)).to.equal(true);
  });
}

settings {
  encodeUrl: true
}
