meta {
  name: Get Job Status by ID - Not Found
  type: http
  seq: 2
}

get {
  url: {{API_URL}}/v3/jobs/nonexistent-job-id-00000000
  body: none
  auth: inherit
}

script:post-response {
  test("GET Job Status Not Found: Status code is Not Found", function () {
    expect(res.getStatus()).to.equal(404);
  });

  test("GET Job Status Not Found: Response has title field", function () {
    const body = res.getBody();
    expect(body).to.have.property("title");
  });

  test("GET Job Status Not Found: Response title indicates job not found", function () {
    const body = res.getBody();
    expect(body.title.toLowerCase()).to.contain("not found");
  });
  
  test("GET Job Status Not Found: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:not-found");
  });
}

settings {
  encodeUrl: true
}
