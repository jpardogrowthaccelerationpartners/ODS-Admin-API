meta {
  name: ApiClients - Invalid No Application Id
  type: http
  seq: 4
}

post {
  url: {{API_URL}}/v3/apiclients
  body: json
  auth: bearer
}

auth:bearer {
  token: {{TOKEN}}
}

body:json {
  {
    "name": "Other Test ApiClient",
    "isApproved": true,
    "applicationId": 0,
    "dataStoreIds": [
      {{DataStoreId}}
    ]
  }
}

script:post-response {
  test("POST ApiClients Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("POST ApiClients Invalid: Response matches error format", function () {
      expect(response).to.have.property("title");
      expect(response).to.have.property("errors");
  });
  
  test("POST ApiClients Invalid: Response title is helpful and accurate", function () {
      expect(response.title.toLowerCase()).to.contain("validation");
  });
  
  test("POST ApiClients Invalid: Response errors include messages by property", function () {
      expect(response.errors["ApplicationId"].length).to.equal(1);
  });
  
  test("POST ApiClients Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
  
}

settings {
  encodeUrl: true
}
