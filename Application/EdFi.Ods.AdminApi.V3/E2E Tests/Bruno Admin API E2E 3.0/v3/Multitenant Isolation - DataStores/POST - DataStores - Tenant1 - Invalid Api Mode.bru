meta {
  name: DataStores - Tenant1 - Invalid Api Mode
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/v1/dataStores/
  body: json
  auth: inherit
}

headers {
  Tenant: Tenant1
}

body:json {
  {
      "name": "Test-DataStore-{{DataStoreGUID}}",
      "dataStoreType": "postgresql",
      "connectionString": "{{connectionString}}"
  }
}

script:pre-request {
  bru.setVar("DataStoreGUID", bru.interpolate('{{$guid}}'));
  
}

script:post-response {
  test("Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("Response matches error format", function () {
      expect(response).to.have.property("detail");
  });
  
  test("Response title is helpful and accurate", function () {
      expect(response.detail.toLowerCase()).to.contain("wrong api version for this instance mode.");
  });
  
  test("Type check: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:version-mismatch");
  });
}

settings {
  encodeUrl: true
}
