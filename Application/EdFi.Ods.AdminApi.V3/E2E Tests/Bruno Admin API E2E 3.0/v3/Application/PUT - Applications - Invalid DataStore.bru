meta {
  name: Applications - Invalid DataStore
  type: http
  seq: 20
}

put {
  url: {{API_URL}}/v3/applications/{{CreatedApplicationId}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": {{CreatedApplicationId}},
    "applicationName": "Updated Application Name",
    "vendorId": {{OtherApplicationVendorId}},
    "claimSetName": "{{UpdatedApplicationClaimSetName}}",
    "profileIds": [],
    "educationOrganizationIds": [1234],
    "dataStoreIds": [ 9999 ]
  }
  
}

script:post-response {
  test("PUT Application Invalid DataStore: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  const errors = res.getBody().errors;
  
  test("PUT Application Invalid DataStore: Response matches error format", function () {
      expect(response).to.have.property("title");
      expect(response).to.have.property("errors");
  });
  
  test("PUT Application Invalid DataStore: Response title is helpful and accurate", function () {
      expect(response.title.toLowerCase()).to.contain("validation");
  });
  
  test("PUT Application Invalid DataStore: Response errors include messages by property", function () {
      expect(response.errors.DataStoreIds.length).to.equal(1);
      expect(response.errors.DataStoreIds[0]).to.contain("not found");
  });
  
  test("PUT Application Invalid DataStore: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
  
}

settings {
  encodeUrl: true
}
