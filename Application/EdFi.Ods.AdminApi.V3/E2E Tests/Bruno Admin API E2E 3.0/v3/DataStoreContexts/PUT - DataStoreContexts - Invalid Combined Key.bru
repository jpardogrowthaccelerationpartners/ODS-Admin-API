meta {
  name: DataStoreContexts - Invalid Combined Key
  type: http
  seq: 20
}

put {
  url: {{API_URL}}/v3/dataStoreContexts/{{CreatedDataStoreContextId}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": {{CreatedDataStoreContextId}},
    "dataStoreId": {{DataStoreId}},
    "contextKey": "ckey2",
    "contextValue": "cvalue"
  }
}

script:pre-request {
  console.log("🔧 Setting pre environment to ignore SSL certificates...");
  
  // Safely set Node.js environment variable if available (CLI only)
  try {
    if (typeof process !== 'undefined' && process.env) {
      process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
    }
  } catch (e) {
    // Ignore in UI environment
  }
  
  const axios = require('axios');
  const API_URL = bru.getEnvVar("API_URL");
  const TOKEN = bru.getEnvVar("TOKEN");

  // Configure axios to handle SSL and network issues
  const axiosConfig = {
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${TOKEN}`
    },
    validateStatus: function (status) {
      return status < 500;
    },
    timeout: 30000
  };

  // Add tenant header if multitenant mode is enabled
  if (bru.getEnvVar("isMultitenant") == "true") {
    axiosConfig.headers['Tenant'] = `${bru.getEnvVar("tenant1")}`;
  }

  try {
    const DataStoreContextsResponse = await axios.post(`${API_URL}/v3/dataStoreContexts`, {
      "dataStoreId": `${bru.getVar("DataStoreId")}`,
      "contextKey": "ckey2",
      "contextValue": "cvalue2"
    }, axiosConfig);

    if (DataStoreContextsResponse.status === 201) {
      console.log("✅ DataStoreContexts created successfully");
      let headers = DataStoreContextsResponse.headers; 
      expect(headers).to.have.property("location");
      const locationHeader = headers.location;
      if(locationHeader) {
          const locationStr = Array.isArray(locationHeader) ? locationHeader[0] : locationHeader;
          const id = locationStr.split("/").pop();
          if(id) {
              bru.setVar("OtherDataStoreContextId", id);
          }
      }
    } else {
      console.log("❌ Failed to create DataStoreContexts");
      console.log("Status:", DataStoreContextsResponse.status);
      console.log("Response data:", JSON.stringify(DataStoreContextsResponse.data, null, 2));
      throw new Error(`Failed to create DataStoreContexts - Status: ${DataStoreContextsResponse.status}, Data: ${JSON.stringify(DataStoreContextsResponse.data)}`);
    }
    
  } catch (error) {
    console.log("Error in pre-request setup:", error.message);
  }

}

script:post-response {
  test("PUT DataStoreContexts Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
   const response = res.getBody();
   
  test("PUT DataStoreContexts Invalid: Response matches error format", function () {
      expect(response).to.have.property("title");
  });
  
  
  test("PUT DataStore Contexts Invalid DataStore: Response errors combined key validation", function () {
       expect(response.title).to.contain("Validation failed");
       expect(response.errors).to.be.an("object").and.not.to.be.empty;
       expect(response.errors[""]).to.be.an("array").that.includes("The combined key DataStore id and context key must be unique.");
   });
  
  test("PUT DataStoreContexts Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
}

settings {
  encodeUrl: true
}
