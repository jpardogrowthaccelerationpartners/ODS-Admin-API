meta {
  name: DataStoreContexts - Invalid Combined Key
  type: http
  seq: 6
}

post {
  url: {{API_URL}}/v3/dataStoreContexts/
  body: json
  auth: inherit
}

body:json {
  {
    "dataStoreId": {{DataStoreId}},
    "contextKey": "ckey",
    "contextValue": "cvalue"
  }
}

script:post-response {
  test("POST DataStore Contexts Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("POST DataStore Contexts Invalid: Response matches title property", function () {
      expect(response).to.have.property("title");
  });
  
  
  test("POST DataStore Contexts Invalid DataStore: Response errors combined key validation", function () {
      expect(response.title).to.contain("Validation failed");
      expect(response.errors).to.be.an("object").and.not.to.be.empty;
      expect(response.errors[""]).to.be.an("array").that.includes("The combined key DataStore id and context key must be unique.");
  });
  
  test("POST DataStore Contexts Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
  
  
  
}

settings {
  encodeUrl: true
}
