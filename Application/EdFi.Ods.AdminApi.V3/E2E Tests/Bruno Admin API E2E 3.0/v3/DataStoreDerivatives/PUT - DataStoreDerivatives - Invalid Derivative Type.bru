meta {
  name: DataStoreDerivatives - Invalid Derivative Type
  type: http
  seq: 20
}

put {
  url: {{API_URL}}/v3/dataStoreDerivatives/{{CreatedDataStoreDerivativeId}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": {{CreatedDataStoreDerivativeId}},
    "dataStoreId": 0,
    "derivativeType": "invalid",
    "connectionString": "{{connectionString}}"
  }
}

script:post-response {
  test("PUT DataStoreDerivatives Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("PUT DataStore Derivatives Invalid: DerivativeType included", function () {
      expect(response.errors).to.have.property('DerivativeType');
  });
  
  test("PUT DataStore Derivatives Invalid: DerivativeType value allowed", function () {
       expect(response.errors.DerivativeType[0]).to.contain("The value for the Derivative type is not allowed. The only accepted values are: 'ReadReplica' or 'Snapshot'");
  });
  
  test("PUT DataStoreDerivatives Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
  
  
}

settings {
  encodeUrl: true
}
