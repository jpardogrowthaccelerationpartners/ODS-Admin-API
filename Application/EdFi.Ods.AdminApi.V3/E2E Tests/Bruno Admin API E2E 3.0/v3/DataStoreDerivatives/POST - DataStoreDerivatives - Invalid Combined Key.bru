meta {
  name: DataStoreDerivatives - Invalid Combined Key
  type: http
  seq: 8
}

post {
  url: {{API_URL}}/v3/dataStoreDerivatives/
  body: json
  auth: inherit
}

body:json {
  {
    "dataStoreId": {{DataStoreId}},
    "derivativeType": "ReadReplica",
    "connectionString": "{{connectionString}}"
  }
}

script:post-response {
  test("POST DataStore Derivatives Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("POST DataStore Derivatives Invalid: Response matches title property", function () {
      expect(response).to.have.property("title");
  });
  
  
  test("POST DataStore Derivatives Invalid DataStore: Response errors include messages by property", function () {
      expect(response.title).to.contain("Validation failed");
      expect(response.errors).to.be.an("object").and.not.to.be.empty;
      expect(response.errors[""]).to.be.an("array").that.includes("The combined key DataStore id and derivative type must be unique.");
  });
  
  test("POST DataStore Derivatives Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
}

settings {
  encodeUrl: true
}
