meta {
  name: DataStoreDerivatives - Invalid Combined Key
  type: http
  seq: 24
}

put {
  url: {{API_URL}}/v3/dataStoreDerivatives/{{CreatedDataStoreDerivativeId}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": {{CreatedDataStoreDerivativeId}},
    "dataStoreId": {{DataStoreId}},
    "derivativeType": "Snapshot",
    "connectionString": "{{connectionString}}"
  }
}

script:pre-request {
  console.log("🔧 Setting pre environment to ignore SSL certificates...");
  
  // Safely set Node.js environment variable if available (CLI only)
  try {
    if (typeof process !== 'undefined' && process.env) {
      process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
    }
  } catch (e) {
    // Ignore in UI environment
  }
  
  const axios = require('axios');
  const API_URL = bru.getEnvVar("API_URL");
  const TOKEN = bru.getEnvVar("TOKEN");

  // Configure axios to handle SSL and network issues
  const axiosConfig = {
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${TOKEN}`
    },
    validateStatus: function (status) {
      return status < 500;
    },
    timeout: 30000
  };

  // Add tenant header if multitenant mode is enabled
  if (bru.getEnvVar("isMultitenant") == "true") {
    axiosConfig.headers['Tenant'] = `${bru.getEnvVar("tenant1")}`;
  }

  try {
    const DataStoreDerivativesResponse = await axios.post(`${API_URL}/v3/dataStoreDerivatives`, {
      "dataStoreId": `${bru.getVar("DataStoreId")}`,
      "derivativeType": "Snapshot",
      "connectionString": `${bru.getEnvVar("connectionString")}`
    }, axiosConfig);

    if (DataStoreDerivativesResponse.status === 201) {
      console.log("✅ DataStoreDerivatives created successfully");
      let headers = DataStoreDerivativesResponse.headers; 
      expect(headers).to.have.property("location");
      const locationHeader = headers.location;
      if(locationHeader) {
          const locationStr = Array.isArray(locationHeader) ? locationHeader[0] : locationHeader;
          const id = locationStr.split("/").pop();
          if(id) {
              bru.setVar("OtherDataStoreDerivativeId", id);
          }
      }
    } else {
      console.log("❌ Failed to create DataStoreContexts");
      console.log("Status:", DataStoreDerivativesResponse.status);
      console.log("Response data:", JSON.stringify(DataStoreDerivativesResponse.data, null, 2));
      throw new Error(`Failed to create DataStoreContexts - Status: ${DataStoreDerivativesResponse.status}, Data: ${JSON.stringify(DataStoreDerivativesResponse.data)}`);
    }
    
  } catch (error) {
    console.log("Error in pre-request setup:", error.message);
  }

}

script:post-response {
  test("PUT DataStoreDerivatives Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("PUT DataStoreDerivatives Invalid: Response matches error format", function () {
      expect(response).to.have.property("title");
  });
  
  test("PUT DataStoreDerivatives Invalid: Invalid DataStoreId", function () {
      expect(response.title).to.contain("Validation failed");
      expect(response.errors).to.be.an("object").and.not.to.be.empty;
      expect(response.errors[""]).to.be.an("array").that.includes("The combined key DataStore id and derivative type must be unique.");
  });
  
  test("PUT DataStoreDerivatives Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
}

settings {
  encodeUrl: true
}
