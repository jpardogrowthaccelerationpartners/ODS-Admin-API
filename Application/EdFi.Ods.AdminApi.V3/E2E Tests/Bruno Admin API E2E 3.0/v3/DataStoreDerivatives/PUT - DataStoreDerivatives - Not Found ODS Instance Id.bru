meta {
  name: DataStoreDerivatives - Not Found DataStore Id
  type: http
  seq: 23
}

put {
  url: {{API_URL}}/v3/dataStoreDerivatives/{{CreatedDataStoreDerivativeId}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": {{CreatedDataStoreDerivativeId}},
    "dataStoreId": 9000,
    "derivativeType": "ReadReplica",
    "connectionString": "{{connectionString}}"
  }
}

script:post-response {
  test("PUT DataStoreDerivatives Invalid: Status code is Not Found", function () {
      expect(res.getStatus()).to.equal(404);
  });
  
  const response = res.getBody();
  
  test("PUT DataStoreDerivatives Invalid: Response matches error format", function () {
      expect(response).to.have.property("title");
  });
  
  test("PUT DataStoreDerivatives Invalid: Invalid DataStoreId", function () {
      expect(response.title).to.contain("Not found");
      expect(response.title).to.contain("DataStore");
      expect(response.title).to.contain("It may have been recently deleted");
  });
  
  test("PUT DataStoreDerivatives Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:not-found");
  });
}

settings {
  encodeUrl: true
}
