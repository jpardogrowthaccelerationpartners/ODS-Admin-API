meta {
  name: DataStoreDerivatives - Invalid ConnectionString
  type: http
  seq: 5
}

post {
  url: {{API_URL}}/v3/dataStoreDerivatives/
  body: json
  auth: inherit
}

body:json {
  {
    "dataStoreId": {{DataStoreId}},
    "derivativeType": "Snapshot",
    "connectionString": "invalid-connection-string"
  }
}

script:post-response {
  test("POST DataStore Derivatives Invalid: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("POST DataStore Derivatives Invalid: ConnectionString included", function () {
      expect(response.errors).to.have.property('ConnectionString');
  });
  
  test("POST DataStore Derivatives Invalid: ConnectionString value allowed", function () {
       expect(response.errors.ConnectionString[0]).to.contain("The connection string is not valid.");
  });
  
  test("POST DataStore Derivatives Invalid: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
  
  
}

settings {
  encodeUrl: true
}
