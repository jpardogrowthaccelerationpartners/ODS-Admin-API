meta {
  name: ClaimSets - Invalid Name With Whitespace
  type: http
  seq: 11.5
}

post {
  url: {{API_URL}}/v3/claimSets/
  body: json
  auth: inherit
}

body:json {
  {
      "name": "claimset name with space"
  }
}

script:post-response {
  test("POST ClaimSets Invalid Name With Whitespace: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("POST ClaimSets Invalid Name With Whitespace: Response matches error format", function () {
      expect(response).to.have.property("title");
      expect(response).to.have.property("errors");
  });
  
  test("POST ClaimSets Invalid Name With Whitespace: Response title is helpful and accurate", function () {
      expect(response.title.toLowerCase()).to.contain("validation");
  });
  
  test("POST ClaimSets Invalid Name With Whitespace: Response errors include whitespace message", function () {
      expect(response.errors.Name.length).to.be.at.least(1);
      expect(response.errors.Name.some(e => e.toLowerCase().includes("white space"))).to.equal(true);
  });
  
  test("POST ClaimSets Invalid Name With Whitespace: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:bad-request:validation");
  });
  
}

settings {
  encodeUrl: true
}
