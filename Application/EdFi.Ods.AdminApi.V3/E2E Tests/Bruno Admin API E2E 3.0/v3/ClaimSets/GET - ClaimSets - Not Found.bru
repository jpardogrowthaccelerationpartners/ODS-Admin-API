meta {
  name: ClaimSets - Not Found
  type: http
  seq: 55
}

get {
  url: {{API_URL}}/v3/claimSets/{{CreatedClaimSetId}}
  body: none
  auth: inherit
}

script:post-response {
  test("GET ClaimSet NotFound: Status code is Not Found", function () {
      expect(res.getStatus()).to.equal(404);
  });
  
  test("GET ClaimSet NotFound: Response matches error format", function () {
      const response = res.getBody();
  
      expect(response).to.have.property("title");
  });
  
  test("GET ClaimSet NotFound: Response title is helpful and accurate", function () {
      const response = res.getBody();
  
      expect(response.title).to.contain("Not found");
      expect(response.title).to.contain("claimset");
      expect(response.title).to.contain(bru.getVar("CreatedClaimSetId"));
  });
  
  test("GET ClaimSet NotFound: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:not-found");
  });
  
}

settings {
  encodeUrl: true
}
