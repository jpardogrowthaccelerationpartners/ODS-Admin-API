meta {
  name: ResourceClaimClaimSets - Delete Not Found
  type: http
  seq: 40
}

delete {
  url: {{API_URL}}/v3/claimSets/{{CreatedClaimSetId}}/resourceClaimActions/4000
  body: json
  auth: inherit
}

script:post-response {
  test("DELETE ResourceClaimOnClaimSet: Status code is Not Found", function () {
      expect(res.getStatus()).to.equal(404);
  });
  
  test("DELETE ResourceClaimOnClaimSet: type URN is correct", function () {
      const response = res.getBody();
      expect(response.type).to.equal("urn:ed-fi:admin-api:not-found");
  });
}

settings {
  encodeUrl: true
}
