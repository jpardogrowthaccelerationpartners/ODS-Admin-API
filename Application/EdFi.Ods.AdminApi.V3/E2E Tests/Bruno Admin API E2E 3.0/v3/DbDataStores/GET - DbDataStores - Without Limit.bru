meta {
  name: DbDataStores - Without Limit
  type: http
  seq: 10
}

get {
  url: {{API_URL}}/v3/dbDataStores?offset={{offset}}
  body: none
  auth: inherit
}

params:query {
  offset: {{offset}}
}

script:post-response {
  test("GET DbDataStores Without Limit: Status code is OK", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("GET DbDataStores Without Limit: Response is an array", function () {
    expect(res.getBody()).to.be.an("array");
  });
}

settings {
  encodeUrl: true
}
