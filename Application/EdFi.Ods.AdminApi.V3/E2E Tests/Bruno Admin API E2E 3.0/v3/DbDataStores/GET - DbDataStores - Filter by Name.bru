meta {
  name: DbDataStores - Filter by Name
  type: http
  seq: 8
}

get {
  url: {{API_URL}}/v3/dbDataStores?name=Test DB Instance
  body: none
  auth: inherit
}

params:query {
  name: Test DB Instance
}

script:post-response {
  test("GET DbDataStores Filter by Name: Status code is OK", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("GET DbDataStores Filter by Name: Response is an array", function () {
    expect(res.getBody()).to.be.an("array");
  });

  test("GET DbDataStores Filter by Name: All results match the name filter", function () {
    const results = res.getBody();
    results.forEach(function (item) {
      expect(item.name).to.equal("Test DB Instance");
    });
  });
}

settings {
  encodeUrl: true
}
